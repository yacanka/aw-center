# AW Center production environment example.
# Copy values into your secret manager or deployment environment; do not commit real secrets.

SECRET_KEY=replace-with-a-long-random-secret-at-least-50-characters-long
DEBUG=False
LOG_LEVEL=INFO

IPV4_ADDRESS=0.0.0.0
PORT=8000
ALLOWED_HOSTS=awcenter.example.com,127.0.0.1,localhost

DATABASE_URL=postgres://awcenter:replace-password@database:5432/awcenter
DB_OLD_URL=sqlite:////app/db_old.sqlite3
DATABASE_CONN_MAX_AGE=60
CACHE_URL=redis://redis:6379/1

CORS_ALLOWED_ORIGINS=https://awcenter.example.com
CSRF_TRUSTED_ORIGINS=https://awcenter.example.com
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
USE_X_FORWARDED_HOST=True

AUTH_COOKIE_NAME=auth_token
AUTH_COOKIE_MAX_AGE=1209600
AUTH_COOKIE_SAMESITE=Lax
AUTH_COOKIE_SECURE=True
AUTH_TOKEN_RESPONSE_ENABLED=False
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax

DOCPROOF_URL=https://docproof.example.com
DOORS_EXECUTABLE=/opt/doors/doors
DOORS_DATABASE=36677@doors.example.com
DOORS_OLE_PROG_ID=DOORS.Application
DOORS_PREFER_ACTIVE_INSTANCE=True
DOORS_AUTO_START_CLIENT=False
DOORS_STARTUP_TIMEOUT_SECONDS=30
DOORS_RUN_TIMEOUT_SECONDS=120
DOORS_MAX_RESULT_BYTES=10485760

TEAMCENTER_BASE_URL=https://teamcenter.example.com/tc
TEAMCENTER_SERVICE_ROOT=RestServices
TEAMCENTER_AUTH_MODE=password
TEAMCENTER_USERNAME=
TEAMCENTER_PASSWORD=
TEAMCENTER_GROUP=
TEAMCENTER_ROLE=
TEAMCENTER_VERIFY_SSL=true
# Cookie-mode alternatives; keep these values in a secret manager.
TEAMCENTER_JSESSIONID=
TEAMCENTER_XSRF_TOKEN=
TEAMCENTER_CONNECT_TIMEOUT_SECONDS=10
TEAMCENTER_READ_TIMEOUT_SECONDS=60
TEAMCENTER_MAX_READ_RETRIES=2
TEAMCENTER_MAX_RESPONSE_BYTES=10485760
JIRA_LEGACY_URL=https://jira-legacy.example.com
JIRA_BTB_URL=https://jira.example.com
AW_USERNAME=
AW_PASSWORD=
FFMPEG_EXECUTABLE=ffmpeg
SOFFICE_BIN=soffice
PDFTOPPM_BIN=pdftoppm

FRONTEND_RESET_URL=https://awcenter.example.com/app/login
FRONTEND_DIST_DIR=/app/frontend-dist

# Frontend build variables.
VITE_API_URL=https://awcenter.example.com
VITE_API_TIMEOUT_MS=10000
VITE_APP_TITLE=AW Center
VITE_VERSION=production
