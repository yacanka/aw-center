{
  "name": "aw-center",
  "version": "1.1.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/check-bundle-budget.mjs && node scripts/postbuild.js",
    "typecheck": "vue-tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,js,vue}\" \"*.{json,ts}\" \"scripts/**/*.js\" \"scripts/check-bundle-budget.mjs\" \"scripts/test-naive-registration.mjs\" \"scripts/test-outlook-attachments.mjs\" \"scripts/test-dcc-jobs.mjs\" \"scripts/test-compdoc-imports.mjs\" \"scripts/test-people-search.mjs\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,vue}\" \"*.{json,ts}\" \"scripts/**/*.js\" \"scripts/check-bundle-budget.mjs\" \"scripts/test-naive-registration.mjs\" \"scripts/test-outlook-attachments.mjs\" \"scripts/test-dcc-jobs.mjs\" \"scripts/test-compdoc-imports.mjs\" \"scripts/test-people-search.mjs\"",
    "test:commands": "node --experimental-strip-types --experimental-default-type=module --test scripts/test-command-search.mjs",
    "test:access": "node --experimental-strip-types --experimental-default-type=module --test scripts/test-route-access.mjs",
    "test:errors": "node --experimental-strip-types --experimental-default-type=module --test scripts/test-api-errors.mjs",
    "test:stores": "node --test scripts/test-store-boundaries.mjs",
    "test:tables": "node --experimental-strip-types --experimental-default-type=module --test scripts/test-table-filters.mjs",
    "test:ui-registration": "node --test scripts/test-naive-registration.mjs",
    "test:uploads": "node --experimental-strip-types --experimental-default-type=module --test scripts/test-uploads.mjs",
    "test:outlook": "node --experimental-strip-types --experimental-default-type=module --test scripts/test-outlook-attachments.mjs",
    "test:dcc": "node --test scripts/test-dcc-jobs.mjs",
    "test:compdoc-refresh": "node --test scripts/test-compdoc-refresh.mjs",
    "test:compdoc": "node --experimental-strip-types --experimental-default-type=module --test scripts/test-compdoc-imports.mjs",
    "test:people-search": "node --test scripts/test-people-search.mjs",
    "test:ci": "npm run test:commands && npm run test:access && npm run test:errors && npm run test:stores && npm run test:tables && npm run test:ui-registration && npm run test:uploads && npm run test:outlook && npm run test:dcc && npm run test:compdoc-refresh && npm run test:compdoc && npm run test:people-search",
    "serve": "vite preview"
  },
  "dependencies": {
    "@energiency/chartjs-plugin-piechart-outlabels": "^1.3.5",
    "@vicons/fluent": "^0.13.0",
    "chart.js": "^4.5.0",
    "chartjs-adapter-date-fns": "^3.0.0",
    "chartjs-plugin-annotation": "^3.1.0",
    "axios": "^1.18.0",
    "markdown-it": "^14.2.0",
    "naive-ui": "^2.41.0",
    "pinia": "^3.0.2",
    "vue": "^3.5.13",
    "vue-audio-visual": "^3.0.11",
    "vue-chartjs": "^5.3.2",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/compiler-sfc": "^3.5.13",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "vfonts": "^0.1.0",
    "vite": "^8.0.16",
    "vue-tsc": "^2.2.10"
  },
  "overrides": {
    "axios": "^1.18.0",
    "brace-expansion": "^2.0.3",
    "esbuild": "^0.28.1",
    "follow-redirects": "^1.16.0",
    "form-data": "^4.0.6",
    "lodash": "^4.18.1",
    "lodash-es": "^4.18.1",
    "markdown-it": "^14.2.0",
    "picomatch": "^4.0.4",
    "postcss": "^8.5.15",
    "vite": "^8.0.16"
  }
}
