{
  "name": "aw-center",
  "version": "1.1.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/postbuild.js",
    "typecheck": "vue-tsc --noEmit",
    "format:check": "prettier --check \"src/**/*.{ts,js,vue}\" \"*.{json,ts}\" \"scripts/**/*.js\"",
    "serve": "vite preview",
    "deploy": "bash scripts/deploy.sh",
    "start": "node server.js",
    "typecheck:ci": "vue-tsc --noEmit --noCheck"
  },
  "dependencies": {
    "@energiency/chartjs-plugin-piechart-outlabels": "^1.3.5",
    "@vicons/fluent": "^0.13.0",
    "chart.js": "^4.5.0",
    "chartjs-adapter-date-fns": "^3.0.0",
    "chartjs-plugin-annotation": "^3.1.0",
    "axios": "^1.9.0",
    "markdown-it": "^14.1.0",
    "naive-ui": "^2.41.0",
    "pinia": "^3.0.2",
    "vue": "^3.5.13",
    "vue-audio-visual": "^3.0.11",
    "vue-chartjs": "^5.3.2",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/compiler-sfc": "^3.5.13",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "vfonts": "^0.1.0",
    "vite": "^6.3.5",
    "vue-tsc": "^2.2.10"
  }
}
